{
  "name": "chessground-starter",
  "private": true,
  "version": "0.0.1",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
